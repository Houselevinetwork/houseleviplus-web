<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Your Sign-in Code - House Levi+</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
        background-color: #f5f5f5;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }
      .header {
        background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
        color: white;
        padding: 40px 20px;
        text-align: center;
      }
      .logo {
        font-size: 2.5rem;
        font-weight: 300;
        letter-spacing: -0.03em;
        margin: 0;
      }
      .logo-accent {
        color: #4169E1;
      }
      .tagline {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.7);
        margin: 10px 0 0 0;
        letter-spacing: 0.05em;
      }
      .content {
        padding: 40px 30px;
        color: #333333;
        line-height: 1.6;
      }
      .greeting {
        font-size: 1.5rem;
        font-weight: 400;
        margin: 0 0 20px 0;
        color: #000000;
      }
      .message {
        font-size: 1rem;
        margin: 0 0 30px 0;
        color: #666666;
      }
      .code-container {
        background: linear-gradient(135deg, #f4f4f4 0%, #e8e8e8 100%);
        padding: 30px;
        text-align: center;
        border-radius: 8px;
        margin: 40px 0;
      }
      .code {
        font-size: 3rem;
        font-weight: 700;
        letter-spacing: 0.3em;
        color: #000000;
        margin: 0;
        font-family: 'Courier New', monospace;
      }
      .code-label {
        font-size: 0.875rem;
        color: #666666;
        margin: 10px 0 0 0;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .expiry {
        font-size: 0.875rem;
        color: #999999;
        text-align: center;
        margin: 20px 0;
      }
      .expiry-highlight {
        color: #4169E1;
        font-weight: 500;
      }
      .footer {
        background-color: #f9f9f9;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #eeeeee;
      }
      .footer-text {
        font-size: 0.75rem;
        color: #999999;
        margin: 5px 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1 class="logo">HOUSE LEVI<span class="logo-accent">+</span></h1>
        <p class="tagline">All Things Theatre and Film</p>
      </div>
      
      <div class="content">
        <h2 class="greeting">Your Sign-in Code</h2>
        
        <p class="message">
          Enter this code to sign in to House Levi+:
        </p>
        
        <div class="code-container">
          <p class="code">{{otpCode}}</p>
          <p class="code-label">Verification Code</p>
        </div>
        
        <p class="expiry">
          This code will expire in <span class="expiry-highlight">10 minutes</span>.
        </p>
        
        <p class="message" style="margin-top: 30px; font-size: 0.875rem; text-align: center;">
          If you didn't request this code, please ignore this email.
        </p>
      </div>
      
      <div class="footer">
        <p class="footer-text">This is an automated message. Please do not reply to this email.</p>
        <p class="footer-text">© 2026 House Levi+. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>