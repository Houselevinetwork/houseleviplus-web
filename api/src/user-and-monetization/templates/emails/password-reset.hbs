<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Reset Your Password - House Levi+</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
        background-color: #f5f5f5;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }
      .header {
        background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
        color: white;
        padding: 40px 20px;
        text-align: center;
      }
      .logo {
        font-size: 2.5rem;
        font-weight: 300;
        letter-spacing: -0.03em;
        margin: 0;
      }
      .logo-accent {
        color: #4169E1;
      }
      .tagline {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.7);
        margin: 10px 0 0 0;
        letter-spacing: 0.05em;
      }
      .content {
        padding: 40px 30px;
        color: #333333;
        line-height: 1.6;
      }
      .greeting {
        font-size: 1.5rem;
        font-weight: 400;
        margin: 0 0 20px 0;
        color: #000000;
      }
      .message {
        font-size: 1rem;
        margin: 0 0 30px 0;
        color: #666666;
      }
      .button-container {
        text-align: center;
        margin: 40px 0;
      }
      .button {
        display: inline-block;
        background-color: #4169E1;
        color: #ffffff;
        padding: 16px 48px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 1.125rem;
        font-weight: 500;
        transition: background-color 0.3s;
      }
      .button:hover {
        background-color: #3154c7;
      }
      .expiry {
        font-size: 0.875rem;
        color: #999999;
        text-align: center;
        margin: 20px 0;
      }
      .expiry-highlight {
        color: #4169E1;
        font-weight: 500;
      }
      .footer {
        background-color: #f9f9f9;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #eeeeee;
      }
      .footer-text {
        font-size: 0.75rem;
        color: #999999;
        margin: 5px 0;
      }
      .link {
        color: #4169E1;
        text-decoration: none;
        word-break: break-all;
      }
      .warning {
        background-color: #fff3cd;
        border-left: 4px solid #ffc107;
        padding: 15px;
        margin: 30px 0;
        border-radius: 4px;
      }
      .warning-text {
        font-size: 0.875rem;
        color: #856404;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1 class="logo">HOUSE LEVI<span class="logo-accent">+</span></h1>
        <p class="tagline">All Things Theatre and Film</p>
      </div>
      
      <div class="content">
        <h2 class="greeting">Reset Your Password</h2>
        
        <p class="message">
          Hi {{firstName}},
        </p>
        
        <p class="message">
          We received a request to reset your password for your House Levi+ account. Click the button below to create a new password:
        </p>
        
        <div class="button-container">
          <a href="{{resetUrl}}" class="button">Reset Password</a>
        </div>
        
        <p class="expiry">
          This link will expire in <span class="expiry-highlight">1 hour</span>.
        </p>
        
        <div class="warning">
          <p class="warning-text">
            <strong>Security Notice:</strong> If you didn't request this password reset, please ignore this email. Your password will remain unchanged.
          </p>
        </div>
        
        <p class="message" style="margin-top: 30px; font-size: 0.875rem;">
          If the button doesn't work, copy and paste this link into your browser:
        </p>
        <p style="text-align: center;">
          <a href="{{resetUrl}}" class="link">{{resetUrl}}</a>
        </p>
      </div>
      
      <div class="footer">
        <p class="footer-text">Need help? Contact us at support@houselevi.network</p>
        <p class="footer-text">© 2026 House Levi+. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>