# =====================================
# HOUSE LEVI+ ENVIRONMENT TEMPLATE
# =====================================
# Copy to .env.development or .env.production and fill in real values.
# NEVER commit .env or .env.production to git.

NODE_ENV=development

# =====================================
# SERVER
# =====================================
PORT=4000

# =====================================
# URLS
# =====================================
BACKEND_URL=
FRONTEND_URL=
ADMIN_FRONTEND_URL=
APP_URL=

# =====================================
# DATABASE
# =====================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=yourapp

# =====================================
# EMAIL
# =====================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=House Levi+
SUPPORT_EMAIL=support@houselevi.com

# =====================================
# JWT
# =====================================
JWT_SECRET=generate-a-secure-random-string-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_EXPIRY=30d

# =====================================
# PESAPAL PAYMENT
# =====================================
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_API_URL=https://pay.pesapal.com/v3/api
PESAPAL_IPN_ID=
PESAPAL_MERCHANT_EMAIL=
PESAPAL_CALLBACK_URL=https://api.houselevi.com/billing/pesapal-webhook
PESAPAL_IPN_URL=https://api.houselevi.com/billing/pesapal-webhook

