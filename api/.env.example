# =====================================
# 🌍 ENVIRONMENT CONFIGURATION TEMPLATE
# =====================================
# Copy this file to .env.development or .env.production
# and fill in your actual values

NODE_ENV=development

# =====================================
# 🚀 SERVER CONFIGURATION
# =====================================
PORT=4000

# =====================================
# 🌐 URL CONFIGURATION
# =====================================
# Development:
# BACKEND_URL=http://localhost:4000
# FRONTEND_URL=http://localhost:5173
# ADMIN_FRONTEND_URL=http://localhost:8080

# Production:
# BACKEND_URL=https://api.reelafrika.co.ke
# FRONTEND_URL=https://www.reelafrika.co.ke
# ADMIN_FRONTEND_URL=https://studio.reelafrika.co.ke

BACKEND_URL=
FRONTEND_URL=
ADMIN_FRONTEND_URL=
APP_URL=

# =====================================
# 💾 DATABASE (MongoDB)
# =====================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# =====================================
# 📧 EMAIL CONFIGURATION
# =====================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Your App Name
SUPPORT_EMAIL=support@yourdomain.com

# =====================================
# 🔐 JWT AUTHENTICATION
# =====================================
JWT_SECRET=generate-a-secure-random-string-here
JWT_EXPIRES_IN=7d

# =====================================
# 💳 PESAPAL PAYMENT GATEWAY
# =====================================
PESAPAL_CONSUMER_KEY=your-consumer-key
PESAPAL_CONSUMER_SECRET=your-consumer-secret
PESAPAL_API_URL=https://pay.pesapal.com/v3/api
PESAPAL_IPN_ID=your-ipn-id
PESAPAL_MERCHANT_EMAIL=your-merchant-email@domain.com
PESAPAL_CALLBACK_URL=https://api.yourdomain.com/billing/pesapal-webhook
PESAPAL_IPN_URL=https://api.yourdomain.com/billing/pesapal-webhook

# =====================================
# ☁️ CLOUDFLARE CONFIGURATION
# =====================================
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_PUBLIC_URL=https://your-account-id.r2.cloudflarestorage.com

# R2 Buckets
CLOUDFLARE_R2_BUCKET_MINISODE=your-minisode-bucket
CLOUDFLARE_R2_BUCKET_REELFILM=your-reelfilm-bucket
CLOUDFLARE_R2_BUCKET_TV_EPISODE=your-tv-bucket
CLOUDFLARE_R2_BUCKET_MOVIE=your-movie-bucket
CLOUDFLARE_R2_BUCKET_PODCAST=your-podcast-bucket
CLOUDFLARE_R2_BUCKET_MUSIC=your-music-bucket
CLOUDFLARE_R2_BUCKET_STAGEPLAY=your-stageplay-bucket

# Cloudflare Stream
CLOUDFLARE_STREAM_API_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/stream
CLOUDFLARE_STREAM_API_TOKEN=your-stream-api-token
CLOUDFLARE_STREAM_UPLOAD_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/stream
CLOUDFLARE_STREAM_CUSTOMER_CODE=your-customer-code

# =====================================
# 🎯 CORS ORIGINS
# =====================================
# Development: http://localhost:5173,http://localhost:8080
# Production: https://www.yourdomain.com,https://studio.yourdomain.com
ALLOWED_ORIGINS=

# =====================================
# 🔒 SECURITY (Production Only)
# =====================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=generate-another-secure-random-string
SESSION_MAX_AGE=86400000
TRUST_PROXY=true